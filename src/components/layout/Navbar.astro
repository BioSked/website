---
import { NavbarActions } from "@/components/layout/NavbarActions"
import { useTranslations } from "@/i18n/i18n";
import { navLinksFor } from "@/i18n/navLinks";
import { LOCALE_CODES, LOCALE_LABELS, altPathFor, type LocaleCode } from "@/i18n/locales";

interface Props {
    currentPage: string;
}
const { currentPage } = Astro.props;

const pathname = currentPage?.replace(/\/$/, '') || '';

const hideNavbar = ['/signin', '/signup', '/docs', '/not-found', '/forgot-password'].some((route) =>
    pathname.includes(route)
);

const locale = (Astro.currentLocale ?? 'en') as LocaleCode;

// Translate link labels
const t = useTranslations(locale);
const navLinks = navLinksFor(locale).map(link => ({
    ...link,
    label: t(link.label),
    alt: t(link.alt),
    subitems: link.subitems ? link.subitems.map(subitem => ({
        ...subitem,
        label: t(subitem.label),
        alt: t(subitem.alt),
    })) : link.subitems
}));

const demoCta = {
    label: t('cta.demo'),
    href: locale === 'en' ? '/demo' : `/${locale}/demo`,
};
const homeHref = locale === 'en' ? '/' : `/${locale}/`;

const languages = LOCALE_CODES.map((code) => ({
    code,
    label: LOCALE_LABELS[code],
    href: altPathFor(Astro.url.pathname, code),
    active: code === locale,
}));
---

{!hideNavbar && (
    <NavbarActions client:idle pagename={Astro.url.pathname} navLinks={navLinks} demoCta={demoCta} homeHref={homeHref} languages={languages}/>
)}
