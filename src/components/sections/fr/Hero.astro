---
import Button from '@/components/ui/Button.astro';
import DecorativeDust from '@/components/ui/DecorativeDust.astro';
import { Image } from 'astro:assets';
import mobileInHand from '@/assets/layout/mobilehand-fr.webp';
import GroupIcon from '@/assets/layout/group2.svg';
import HospitalIcon from '@/assets/layout/hospital.svg';
import EarthIcon from '@/assets/layout/earth.svg';
import dateView from '@/assets/screenshots/dateview.png';

interface Props {
  title?: string;
  lead?: string;
  demoHref?: string;
}
const {
  title = 'La plateforme de planification médicale reconnue qui associe IA, équité et simplicité',
  lead = 'Gardes, astreintes, désidératas : des plannings conformes et équitables, générés en heures, pas en jours.',
  demoHref = '/fr/demo/',
} = Astro.props;
---

<section class="section-padding relative">
  <div class="absolute inset-0 z-0 pointer-events-none">
    <DecorativeDust
      class="absolute top-1/4 right-0 hidden size-[800px] bg-no-repeat dust-fade md:block"
    />
    <!-- <div class="blob-accent absolute top-0 left-0 size-[700px] rounded-full opacity-25 blur-3xl dark:opacity-40 -translate-x-1/3 -translate-y-1/3"></div>
    <div class="blob-primary absolute top-1/4 right-0 size-[650px] rounded-full opacity-30 blur-3xl dark:opacity-55 translate-x-1/4"></div>
    <div class="blob-secondary absolute top-1/2 left-1/4 size-[550px] rounded-full opacity-20 blur-3xl dark:opacity-35"></div>
    <div class="blob-accent absolute bottom-1/4 right-1/3 size-[450px] rounded-full opacity-20 blur-3xl dark:opacity-35"></div> -->
  </div>
  
  <div class="container max-w-5xl relative z-10">
    <div class="flex">
      <div class="flex max-w-[900px] flex-col gap-5 md:gap-6 flex-3">
        <h1 class="text-display-hero text-left">
          {title}
          <!-- <br class="hidden md:block" /> -->
        </h1>

        <p class="max-w-[90%] text-lead">
          {lead}
        </p>

        <div class="flex flex-wrap gap-2">
          <a href={demoHref}>
            <Button
              size="lg"
              variant="default"
              className="rounded-full shadow-sm shadow-primary/50 hover:shadow-md px-5 font-bold ease-in-out transition-all scale-100 hover:scale-103 duration-200 border border-white/50"
            >
              Demander une démo
            </Button>
          </a>

          <a href="/fr/cas-clients/">
            <Button
              size="lg"
              variant="ghost"
              className="rounded-full shadow-none font-semibold px-3 text-card-foreground hover:bg-card-foreground/5"
            >
              Voir les cas clients
            </Button>
          </a>
        </div>
        <div class="font-semibold text-foreground/80 text-sm">
          <GroupIcon class="inline-block size-7 mb-1 mr-1"/>50 000+ utilisateurs
          <span class="mx-2 font-light hidden lg:inline">|</span>
          <hr class="lg:hidden border-none mb-1">
          <HospitalIcon class="inline-block size-5 mb-1 mr-1"/>1 000+ sites de santé
          <span class="mx-2 font-light hidden lg:inline">|</span>
          <hr class="lg:hidden border-none mb-2">
          <EarthIcon class="inline-block size-5 mb-1 mr-1"/>9 pays
        </div>
        <div class="text-foreground/80 text-sm">
          CHU Angers · CHIREC · IRIS GRIM · IMALLIANCE · Les Cèdres — <a href="/fr/cas-clients/" class="text-cyan-700 hover:text-secondary transition-colors font-medium">cas clients</a>
        </div>
      </div>
      <div class="hidden sm:block flex-2">
        <Image 
          src={mobileInHand} 
          alt="Application mobile Momentum — 90 % de gain de temps admin, Assistant IA"
          class="w-200"
          widths={[320, 480, 640, 800]}
          sizes="(min-width: 1280px) 400px, (min-width: 640px) 40vw, 1px"
          format="webp"
          quality={82}
          loading="lazy"
          fetchpriority="low"
        />
      </div>
    </div>
  </div>
  <div class="container mt-10 max-w-7xl">
    <div id="hero-media-container" class="mx-auto w-full overflow-x-auto rounded-xl border border-border bg-background/45 p-1 shadow-[4px_2px_3rem_rgba(0,0,0,.15)] backdrop-blur-sm dark:shadow-[4px_2px_3rem_rgba(0,0,0,.5)] md:p-2">
      <Image
        src={dateView}
        alt="Interface de planification Momentum : vue mensuelle des plannings, gardes et compteurs"
        width={1000}
        height={563}
        widths={[640, 750, 828, 1000, 1280, 1500, 2000]}
        sizes="(min-width: 1280px) 1216px, calc(100vw - 3rem)"
        format="webp"
        quality={85}
        loading="eager"
        fetchpriority="high"
        class="w-full h-auto rounded-lg"
      />
    </div>
  </div>
</section>
