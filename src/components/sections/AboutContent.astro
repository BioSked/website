---
import Card from '@/components/ui/Card.astro';
import Linkedin from '@/assets/logos/linkedin.svg';
import AIInno from "@/components/sections/AIInnovation.astro";
import cyanDust from '@/assets/layout/cyan-dust_background.webp';
import { Image } from 'astro:assets';
import davidProfile from '@/assets/profile-photos/david_profile.png';
import danProfile from '@/assets/profile-photos/dan_profile.png';
import sarahProfile from '@/assets/profile-photos/sarah_profile.jpg';
import marcProfile from '@/assets/profile-photos/marc_profile.jpg';
import xavierProfile from '@/assets/profile-photos/xavier_profile.jpg';
import lakuProfile from '@/assets/profile-photos/laku_profile.jpg';

const LEADERSHIP = [
  {
    id: 1,
    name: 'David Dudok de Wit',
    role: 'CEO',
    linkedinUrl: 'https://www.linkedin.com/in/daviddudokdewit/',
    bio: `Before joining BioSked as CEO, David led growth and product development at Proton, a SaaS platform dedicated to privacy protection, used by over 100 million users worldwide.\n\n
His background as a leader in startups, scale-ups, and international companies, along with his experience across various industries such as healthcare, aviation, technology, and consumer goods, has given him strong expertise in technology, product growth, and innovation.
He has contributed to the success of companies like Nestlé Nespresso, SITA, and Frederique Constant, and has founded his own profitable SaaS company.\n\nDavid holds a BSc and MSc in Information Systems, as well as Reforge certifications in growth and strategy.`,
    image: davidProfile,
  },
  {
    id: 2,
    name: 'Sarah Mertz',
    role: 'Co-Founder, Sales & Marketing Director',
    linkedinUrl: 'https://www.linkedin.com/in/sarahmertz/',
    bio: `Sarah Mertz is currently Vice President of Sales & Marketing for BioSked. She was previously European sales manager at Bio-Optronics and responsible for Momentum sales and marketing in the European Market. She joined Bio-optronics in 2015 as marketing specialist for the Momentum product in Europe.\n\nShe started her career in the French radiology market in 2013 as marketing communication specialist with Global Imaging Online, now NEHS, the leading PACS/RIS provider. Previously, she worked in the plastics and software.\n\nSarah holds a BS in Information Technology and an MBA in international business from the IDRAC Business School.`,
    image: sarahProfile,
  },
];

const BOARD = [
  {
    id: 1,
    name: 'Dan Kerpelman',
    role: 'Co-founder, Chairman',
    linkedinUrl: 'https://www.linkedin.com/in/dkerpelman/',
    bio: `40+ years scaling medical technology companies from startup to exit. Former CEO of Bio-Optronics and multiple public/private healthcare tech businesses. Serves on several healthcare and technology boards.`,
    image: danProfile,
  },
  {
    id: 2,
    name: 'David Dudok de Wit',
    role: 'Director',
    linkedinUrl: 'https://www.linkedin.com/in/daviddudokdewit/',
    bio: `Before joining BioSked as CEO, David led growth and product development at Proton, a SaaS platform dedicated to privacy protection, used by over 100 million users worldwide.\n\n
His background as a leader in startups, scale-ups, and international companies, along with his experience across various industries such as healthcare, aviation, technology, and consumer goods, has given him strong expertise in technology, product growth, and innovation.
He has contributed to the success of companies like Nestlé Nespresso, SITA, and Frederique Constant, and has founded his own profitable SaaS company.\n\nDavid holds a BSc and MSc in Information Systems, as well as Reforge certifications in growth and strategy.`,
    image: davidProfile,
  },
  {
    id: 3,
    name: 'Sarah Mertz',
    role: 'Co-Founder, Director',
    linkedinUrl: 'https://www.linkedin.com/in/sarahmertz/',
    bio: `Sarah Mertz is currently Vice President of Sales & Marketing for BioSked. She was previously European sales manager at Bio-Optronics and responsible for Momentum sales and marketing in the European Market. She joined Bio-optronics in 2015 as marketing specialist for the Momentum product in Europe.\n\nShe started her career in the French radiology market in 2013 as marketing communication specialist with Global Imaging Online, now NEHS, the leading PACS/RIS provider. Previously, she worked in the plastics and software.\n\nSarah holds a BS in Information Technology and an MBA in international business from the IDRAC Business School.`,
    image: sarahProfile,
  },
  {
    id: 4,
    name: 'Marc Degrauwe',
    role: 'Director',
    linkedinUrl: 'https://www.linkedin.com/in/marc-degrauwe-b2882458/',
    bio: ``,
    image: marcProfile,
  },
  {
    id: 5,
    name: 'Xavier Paternot',
    role: 'Director',
    linkedinUrl: 'https://www.linkedin.com/in/xavier-paternot-31a26719/',
    bio: ``,
    image: xavierProfile,
  },
  {
    id: 6,
    name: 'Laku Adedoyin',
    role: 'Director',
    linkedinUrl: 'https://www.linkedin.com/in/lakuad/',
    bio: ``,
    image: lakuProfile,
  }
];
---

<section class="section-padding relative">
  <div class="absolute top-1/4 left-0 size-[800px] bg-no-repeat dust-fade" style={'transform: scaleX(-1); background-image: url("'+cyanDust.src+'");'}></div>
  <div class="container relative max-w-5xl">
    <div>
      <h1 class="text-display-hero">
        Healthcare scheduling
        <br />
        reimagined.
      </h1>
      <p class="text-muted-foreground mt-6 max-w-2xl text-lead">
        Healthcare scheduling is complex—multi-site coverage, rotation fairness, compliance rules, shift preferences, RVU balancing. We built Momentum to handle that complexity automatically, so scheduling teams can focus on strategic workforce planning and physicians can focus on patients.
      </p>
    </div>
  </div>
</section>

  <section class="container max-w-5xl relative">
    <h2 class="text-muted-foreground font-mono text-sm font-semibold tracking-widest mb-4">
      BY THE NUMBERS
    </h2>
    <hr>
    <div class="mt-6 mb-8 grid grid-cols-2 gap-8 md:grid-cols-4">
      <div>
        <h3 class="text-metric-large font-light text-accent">
          1,000+
        </h3>
        <p class="text-muted-foreground mt-1 font-medium">Healthcare sites</p>
      </div>
      <div>
        <h3 class="text-metric-large font-light text-accent">
          50K+
        </h3>
        <p class="text-muted-foreground mt-1 font-medium">Clinicians scheduled</p>
      </div>
      <div>
        <h3 class="text-metric-large font-light text-accent">
          90%
        </h3>
        <p class="text-muted-foreground mt-1 font-medium">
          Admin time saved
        </p>
      </div>
      <div>
        <h3 class="text-metric-large font-light text-accent">
          15+
        </h3>
        <p class="text-muted-foreground mt-1 font-medium">
          Years in healthcare
        </p>
      </div>
    </div>
    <hr>
  </section>

  <section class="lg:py-15 container max-w-5xl py-10 md:py-12 mt-12">
    <h4 class="text-display-section font-bold mb-8">
      Our approach
    </h4>
    <div class="max-w-2xl space-y-4">
      <p class="text-lg leading-relaxed">
        Most scheduling software just digitizes your spreadsheet. Momentum thinks for you.
      </p>
      <p class="text-lg leading-relaxed">
        Our rules-based automation builds schedules automatically—whether you're a solo physician managing your own rotations or a workforce director coordinating across multiple hospitals. You define the rules once (shift patterns, fairness policies, compliance requirements), and Momentum handles the complexity from there.
      </p>
      <p class="text-lg leading-relaxed">
        The result? Fair schedules, fewer disputes, and time back for what matters—patient care, strategic planning, or simply going home on time.
      </p>
    </div>
  </section>

  <AIInno/>

  <section class="lg:py-15 container max-w-5xl py-10 md:py-12 relative">
    <div class="mb-8 md:mb-12">
      <h2 class="text-display-section font-bold">
        Leadership
      </h2>
      <p class="text-muted-foreground mt-4 text-lead">
        Led by healthcare operators and technologists passionate about solving real scheduling problems.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 md:gap-20">
      {LEADERSHIP.map((member) => (
        <Card className="p-0 overflow-hidden group transition-all duration-300 scale-100 hover:scale-101">
          <div class="flex flex-col">
            <div class="flex items-center gap-4">
              {member.image ? (
                <Image
                  src={member.image}
                  alt={member.name}
                  width={160}
                  height={160}
                  class="w-20 h-20 object-cover grayscale transition-all duration-300 group-hover:grayscale-0 rounded shrink-0 shadow-xl shadow-secondary/20"
                  loading="lazy"
                  quality={95}
                  format="webp"
                  densities={[1, 2]}
                />
              ) : (
                <div class="w-20 h-20 rounded bg-muted shrink-0" />
              )}
              <div>
                <h3 class="text-xl font-semibold tracking-tight md:text-2xl text-foreground">
                  {member.name}
                </h3>
                <div class="flex items-center gap-1.5 mt-0">
                  <p class="text-sm">
                    {member.role}
                  </p>
                  <a 
                    href={member.linkedinUrl} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center rol p-0.5 transition-opacity grayscale-1 opacity-80 hover:opacity-100"
                    aria-label={`${member.name} on LinkedIn`}
                  >
                    <img src={Linkedin.src} width="16"/>
                  </a>
                </div>
              </div>
            </div>

            {member.bio && (
              <div class="pt-6 pb-16 md:pb-20">
                <div class="space-y-4 text-sm leading-relaxed md:text-base">
                  {member.bio.split('\n\n').map((paragraph: string) => (
                    <p class="md:text-muted-foreground group-hover:text-foreground transition-text duration-300">{paragraph}</p>
                  ))}
                </div>
              </div>
            )}
          </div>
        </Card>
      ))}
    </div>
  </section>
  <!-- BOARD OF DIRECTORS -->
  <section class="container max-w-5xl pb-10 md:pb-15 lg:pb-25">
    <div class="mb-8 md:mb-12">
      <h2 class="text-display-section font-bold">
        Board of Directors
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 md:gap-1">
      {BOARD.map((member) => (
        <Card className="p-0 overflow-hidden group">
          <div class="flex flex-col">
            <div class="flex items-center gap-4">
              {member.image ? (
                <Image
                  src={member.image}
                  alt={member.name}
                  width={160}
                  height={160}
                  class="w-20 h-20 mt-4 mb-5 object-cover grayscale transition-all duration-300 group-hover:grayscale-0 rounded shrink-0 shadow-lg shadow-secondary/20"
                  loading="lazy"
                  quality={95}
                  format="webp"
                  densities={[1, 2]}
                />
              ) : (
                <div class="w-20 h-20 rounded bg-muted shrink-0" />
              )}
              <div>
                <h3 class="text-xl font-semibold tracking-tight md:text-2xl text-foreground">
                  {member.name}
                </h3>
                <div class="flex items-center gap-1.5 mb-1">
                  <p class="text-sm">
                    {member.role}
                  </p>
                </div>
                <a 
                    href={member.linkedinUrl} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center rol transition-opacity grayscale-1 opacity-25 hover:opacity-90"
                    aria-label={`${member.name} on LinkedIn`}
                >
                    <img src={Linkedin.src} width="16"/>
                </a>
              </div>
            </div>
          </div>
        </Card>
      ))}
    </div>
  </section>
</section>
