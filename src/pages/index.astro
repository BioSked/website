---
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import Manifesto from "@/components/sections/Manifesto.astro";
import Logos from "@/components/sections/Logos.astro";
import FeatureShowcase from "@/components/sections/FeaturesShowcase.astro";
import AIInno from "@/components/sections/AIInnovation.astro";
import CTA from "@/components/sections/CTA.astro";
import Testimonials from "@/components/sections/Testimonials.astro";
// import FullTimelineView from "@/components/sections/FullTimelineView.tsx";
import RVU from "@/components/sections/RVU.astro";
import MobileAppSection from "@/components/sections/intl/MobileAppSection.astro";
import { MOBILE_APP } from "@/i18n/mobileAppContent";
---

<BaseLayout
  title="Momentum: Healthcare Scheduling Software | BioSked"
  description="AI-powered healthcare scheduling software for hospitals, clinics, and medical groups. Automate physician schedules, RVU tracking, shifts, and compliance."
>
	<Hero/>
	<Manifesto/>
	<Testimonials/>
	<!-- <FullTimelineView client:visible={{rootMargin: "150px"}} /> -->
	<a id="momentum"/>
	<FeatureShowcase />
	<RVU />
	<MobileAppSection content={MOBILE_APP['en']} />
	<!-- <Logos/> -->
  <AIInno />
	<CTA />
</BaseLayout>
