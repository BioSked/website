---
import "src/styles/global.css"

import BaseHead from '@/components/BaseHead.astro';
import NavigationProvider from '@/components/elements/NavigationProvider.astro';

import LocalePrefs from '@/components/LocalePrefs.astro';
import ConsentBanner from '@/components/ConsentBanner.astro';
import AnalyticsEvents from '@/components/AnalyticsEvents.astro';
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";

const { title, description, author, noIndex, pageType } = Astro.props;
const currentPath = Astro.url.pathname;
const lang = Astro.currentLocale ?? 'en';
---

<html lang={lang} class="bg-noise">
  <head>
    <BaseHead title={title} description={description} author={author} noIndex={noIndex} pageType={pageType}/>
  </head>
  <body
    data-page-type={pageType}
    class={`h-screen antialiased flex flex-col [--header-height:calc(var(--spacing)*12)] lg:[--header-height:calc(var(--spacing)*18)]`}
  >
    <AnalyticsEvents />
      <svg width="0" height="0" style="position: absolute;">
        <filter id="noise-texture">
            <feTurbulence 
                type="fractalNoise" 
                baseFrequency="0.48" 
                numOctaves="3" 
                seed="0"
                stitchTiles="stitch"/>
            <feColorMatrix type="saturate" values="0"/>
            <feComponentTransfer>
                <feFuncA type="discrete" tableValues="0 0.2"/>
            </feComponentTransfer>
            <feBlend mode="multiply" in="SourceGraphic"/>
        </filter>
    </svg>
    <NavigationProvider currentPath={currentPath}>
      <Navbar currentPage={currentPath}  />
      <main class="flex-1" style="view-transition-name: main;">
        <slot />
      </main>
      <Footer currentPage={currentPath} />
    </NavigationProvider>
    
  	<LocalePrefs />
  	<ConsentBanner />
</body>
</html>
