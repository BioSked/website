---
import '@/styles/global.css';
import { SITE_TITLE, SITE_METADATA } from '../consts';
import { hreflangAlternates, canonicalPathFor, splitLocale } from '@/i18n/locales';

const canonicalPath = canonicalPathFor(Astro.url.pathname);
const canonicalURL = Astro.site
? new URL(canonicalPath, Astro.site)
: null;
const pageLocale = splitLocale(Astro.url.pathname).locale;
const canonicalLocale = splitLocale(canonicalPath).locale;

// True localized equivalents of this page (never a fallback-EN-under-a-locale URL),
// used by the instant locale-switch script below.
const localeAlts: Record<string, string> = {};
for (const a of hreflangAlternates(Astro.url.pathname)) {
    if (a.code !== 'x-default') localeAlts[a.code] = a.path;
}

const { title, description, image, author, noIndex, pageType } = Astro.props;
const finalTitle = title || SITE_METADATA.title.default;
const finalDescription = description || SITE_METADATA.description;
const finalAuthor = author || SITE_METADATA.authors[0].name;
const finalImage = image || SITE_METADATA.openGraph.images[0].url;
const imageURL = new URL(finalImage, Astro.url);
const robotsIndex = noIndex ? false : SITE_METADATA.robots.index;
const robotsFollow = noIndex ? false : SITE_METADATA.robots.follow;
const socialURL = canonicalURL || Astro.url;
const openGraphLocales: Record<string, string> = {
    en: 'en_US',
    fr: 'fr_FR',
    'fr-ch': 'fr_CH',
    de: 'de_DE',
    nl: 'nl_NL',
    it: 'it_IT',
};
const socialImageAlts: Record<string, string> = {
    en: SITE_METADATA.openGraph.images[0].alt,
    fr: 'Application Momentum de BioSked pour la planification du personnel de santé',
    'fr-ch': 'Application Momentum de BioSked pour la planification du personnel de santé',
    de: 'BioSked Momentum App für die Dienstplanung medizinischer Teams',
    nl: 'BioSked Momentum-app voor roosterplanning van medische teams',
    it: 'App BioSked Momentum per la pianificazione dei turni medici',
};
const socialImageAlt = socialImageAlts[canonicalLocale] ?? SITE_METADATA.openGraph.images[0].alt;
const analyticsPageLocation = pageType === 'not-found'
    ? new URL('/__404__', Astro.site ?? 'https://biosked.com').toString()
    : null;
---

<meta charset="utf-8" />

<!--
  Instant locale switch. First-time visitors on the English tree are sent to the
  page in their browser's language before paint (no flash, no banner). Rules:
  - Only redirects FROM the default English tree; a visitor who deep-linked into
    /fr/, /de/, ... is never bounced.
  - An explicit choice (language switcher) is stored and always wins; an English
    preference keeps the English page.
  - Targets only TRUE localized equivalents (hreflang set), so no one is sent to
    English content served under a locale URL. Crawlers (en-US) never redirect.
-->
<script is:inline define:vars={{ localeCurrent: pageLocale, localeAlts }}>
    (function () {
        try {
            if (localeCurrent !== 'en') return;
            var KEY = 'biosked-locale-pref';
            var want = null;
            try { want = localStorage.getItem(KEY); } catch (e) {}
            if (!want) {
                var langs = navigator.languages || [navigator.language || 'en'];
                for (var i = 0; i < langs.length; i++) {
                    var l = String(langs[i]).toLowerCase();
                    if (l === 'fr-ch') { want = 'fr-ch'; break; }
                    if (l.indexOf('fr') === 0) {
                        want = 'fr';
                        try { if (Intl.DateTimeFormat().resolvedOptions().timeZone === 'Europe/Zurich') want = 'fr-ch'; } catch (e) {}
                        break;
                    }
                    if (l.indexOf('de') === 0) { want = 'de'; break; }
                    if (l.indexOf('nl') === 0) { want = 'nl'; break; }
                    if (l.indexOf('it') === 0) { want = 'it'; break; }
                    if (l.indexOf('en') === 0) { want = 'en'; break; }
                }
            }
            if (!want || want === 'en') return;
            var target = localeAlts[want];
            if (!target) return;
            var here = location.pathname.replace(/\/+$/, '') || '/';
            var there = String(target).replace(/\/+$/, '') || '/';
            if (here === there) return;
            location.replace(target + location.search + location.hash);
        } catch (e) {}
    })();
</script>

<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta
    name="robots"
    content={`${robotsIndex ? 'index' : 'noindex'}, ${robotsFollow ? 'follow' : 'nofollow'}`}
/>
{pageType === 'not-found' && <meta name="referrer" content="no-referrer" />}
<meta name="keywords" content={SITE_METADATA.keywords.join(', ')} />
<meta name="author" content={finalAuthor} />
<meta name="creator" content={SITE_METADATA.creator} />
<meta name="publisher" content={SITE_METADATA.publisher} />

<!-- Google tag (gtag.js) -->
<script is:inline define:vars={{ pageLocale, analyticsPageLocation }}>
    // Consent-gated Google Analytics (CNIL "basic" mode).
    // Outside EU/CH timezones: GA loads immediately (no banner shown).
    // Inside: nothing loads until the visitor accepts (ConsentBanner).
    // Global Privacy Control is honored as a standing refusal.
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    window.gtag = gtag;
    gtag('js', new Date());
    gtag('consent', 'default', { ad_storage: 'denied', ad_user_data: 'denied', ad_personalization: 'denied', analytics_storage: 'denied' });
    gtag('set', { site_language: pageLocale, content_group: pageLocale });

    var analyticsHost = location.hostname === 'biosked.com' || location.hostname === 'www.biosked.com';
    window.__bskLoadGA = function () {
        if (!analyticsHost || window.__bskGALoaded) return;
        window.__bskGALoaded = true;
        gtag('consent', 'update', { analytics_storage: 'granted' });
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=GT-NB96M5G7';
        document.head.appendChild(s);
        if (analyticsPageLocation) {
            gtag('config', 'GT-NB96M5G7', {
                page_location: analyticsPageLocation,
                page_referrer: '',
            });
        } else {
            gtag('config', 'GT-NB96M5G7');
        }
        window.dispatchEvent(new Event('bsk:analytics-ready'));
    };

    (function () {
        var choice = null;
        try {
            var raw = localStorage.getItem('biosked-consent');
            if (raw) {
                var parsed = JSON.parse(raw);
                // Choices older than 12 months are re-asked.
                choice = (Date.now() - (parsed.t || 0) < 31536000000) ? parsed.v : null;
            }
        } catch (e) {}
        var gpc = navigator.globalPrivacyControl === true;
        var eu = false;
        try {
            var tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
            eu = /^Europe\//.test(tz) || /^Atlantic\/(Canary|Madeira|Azores|Reykjavik)$/.test(tz);
        } catch (e) {}
        if (gpc || choice === 'denied') return;
        if (choice === 'granted') { window.__bskLoadGA(); return; }
        if (!eu) { window.__bskLoadGA(); return; }
        window.__bskConsentPending = true;
    })();
</script>
<!-- <GoogleTagmanagerPartytown id="GT-NB96M5G7" /> -->

<script is:inline>
    // HubSpot forms lazy loader. The 190KB embed script used to load
    // render-blocking in <head> on EVERY page; now it loads async, once,
    // and only on pages that actually create a form via window.bskHsForm().
    (function () {
        var queue = [];
        var injected = false;
        window.bskHsForm = function (cfg) {
            queue.push(cfg);
            if (injected) return;
            injected = true;
            var s = document.createElement('script');
            s.src = 'https://js-eu1.hsforms.net/forms/embed/v2.js';
            s.async = true;
            s.charset = 'utf-8';
            s.onload = function () {
                if (!window.hbspt) return;
                window.bskHsForm = function (c) { window.hbspt.forms.create(c); };
                queue.forEach(window.bskHsForm);
                queue = [];
            };
            document.head.appendChild(s);
        };
    })();
</script>

<script is:inline>
    (function() {
// const theme = localStorage.getItem('theme') || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
// if (theme === 'dark') document.documentElement.classList.add('dark');
// Force light mode
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
    })();
</script>
<style is:inline>
    html {
        color-scheme: light;
    }
</style>

{
    SITE_METADATA.icons.icon.map((icon) => (
        <link rel="icon" type={icon.type} sizes={icon.sizes} href={icon.url} />
        ))
}
{
    SITE_METADATA.icons.apple.map((icon) => (
        <link rel="apple-touch-icon" sizes={icon.sizes} href={icon.url} />
        ))
}
{
    SITE_METADATA.icons.shortcut.map((icon) => (
        <link rel="shortcut icon" href={icon.url} />
        ))
}

<link rel="manifest" href="/favicon/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
rel="alternate"
type="application/rss+xml"
title={SITE_TITLE}
href={Astro.site ? new URL(pageLocale === 'fr' || pageLocale === 'fr-ch' ? 'fr/rss.xml' : 'rss.xml', Astro.site).toString() : '/rss.xml'}
/>
{hreflangAlternates(Astro.url.pathname).map((alt) => (
    <link rel="alternate" hreflang={alt.code === 'fr-ch' ? 'fr-CH' : alt.code} href={new URL(alt.path, Astro.site ?? 'https://biosked.com').toString()} />
))}
<meta name="generator" content={Astro.generator} />

{canonicalURL && <link rel="canonical" href={canonicalURL} />}


<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />

<meta property="og:type" content="website" />
<meta property="og:url" content={socialURL} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:locale" content={openGraphLocales[canonicalLocale] ?? 'en_US'} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageURL} />
<meta
property="og:image:width"
content={SITE_METADATA.openGraph.images[0].width.toString()}
/>
<meta
property="og:image:height"
content={SITE_METADATA.openGraph.images[0].height.toString()}
/>
<meta property="og:image:alt" content={socialImageAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={socialURL} />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={socialImageAlt} />


