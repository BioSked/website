---
import { splitLocale } from '@/i18n/locales';

/**
 * Locale preferences (no UI). Two DOM-dependent jobs, so this runs in the body:
 * - Records an explicit language choice made via the switcher (a[data-locale-choice])
 *   in localStorage 'biosked-locale-pref'. The instant-switch script in <head>
 *   (BaseHead) then always respects it.
 * - Swiss stickiness: once a visitor has seen a /fr-ch/ page, the conversion links
 *   on shared /fr/ pages keep pointing to the CHF (Swiss) versions.
 *
 * The old "this page is available in X" suggestion banner was removed — first-time
 * language selection is now handled silently and instantly in <head>.
 */
const { locale: current } = splitLocale(Astro.url.pathname);
---

<script is:inline define:vars={{ localeCurrent: current }}>
    (function () {
        var KEY = 'biosked-locale-pref';

        // Record explicit switcher choices so auto-detect never overrides them.
        document.addEventListener('click', function (e) {
            var a = e.target && e.target.closest && e.target.closest('a[data-locale-choice]');
            if (a) { try { localStorage.setItem(KEY, a.getAttribute('data-locale-choice')); } catch (err) {} }
        }, true);

        // Swiss stickiness on shared /fr/ pages.
        try {
            var current = localeCurrent || 'en';
            var FRCH_PAGES = ['/fr/pricing/', '/fr/demo/', '/fr/getquote/', '/fr/securite-donnees/', '/fr/mentions-legales/'];
            if (current === 'fr-ch') sessionStorage.setItem('biosked-frch', '1');
            var stored = null;
            try { stored = localStorage.getItem(KEY); } catch (e) {}
            var frchSticky = stored === 'fr-ch' || sessionStorage.getItem('biosked-frch') === '1';
            if (current === 'fr' && frchSticky) {
                document.querySelectorAll('a[href^="/fr/"], a[href="/fr"]').forEach(function (a) {
                    var h = a.getAttribute('href');
                    var hs = h.charAt(h.length - 1) === '/' ? h : h + '/';
                    if (hs === '/fr/') { a.setAttribute('href', '/fr-ch/'); return; }
                    if (FRCH_PAGES.indexOf(hs) !== -1) a.setAttribute('href', '/fr-ch' + hs.slice(3));
                });
            }
        } catch (e) {}
    })();
</script>
