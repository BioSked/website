---
import BaseLayout from './BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
const { frontmatter } = Astro.props;

const locale = Astro.currentLocale ?? 'en';
const DATE_LOCALES: Record<string, string> = { en: 'en-US', fr: 'fr-FR', 'fr-ch': 'fr-CH', de: 'de-DE', nl: 'nl-NL', it: 'it-IT' };
const BREADCRUMB_LABEL: Record<string, string> = { en: 'News', fr: 'Article', 'fr-ch': 'Article', de: 'Artikel', nl: 'Artikel', it: 'Articolo' };
const blogHref = locale === 'en' ? '/blog/' : `/${locale}/blog/`;

const postDate = new Date(frontmatter.date);
const pubDate = postDate.toLocaleDateString(DATE_LOCALES[locale] ?? 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});

const canonical = new URL(Astro.url.pathname.replace(/\/?$/, '/'), Astro.site ?? 'https://biosked.com').toString();
const articleSchema = JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'BlogPosting',
            headline: frontmatter.title,
            description: frontmatter.description,
            datePublished: new Date(frontmatter.date).toISOString(),
            author: { '@type': 'Organization', name: 'BioSked' },
            publisher: { '@id': 'https://biosked.com/#organization' },
            mainEntityOfPage: canonical,
            inLanguage: locale === 'en' ? 'en' : locale === 'fr' || locale === 'fr-ch' ? 'fr' : locale,
        },
        {
            '@type': 'BreadcrumbList',
            itemListElement: [
                { '@type': 'ListItem', position: 1, name: 'Blog', item: new URL(blogHref, Astro.site ?? 'https://biosked.com').toString() },
                { '@type': 'ListItem', position: 2, name: frontmatter.title, item: canonical },
            ],
        },
    ],
});

const isFrench = locale === 'fr' || locale === 'fr-ch';
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} author={frontmatter.author}>
	<script is:inline type="application/ld+json" set:html={articleSchema} />
	<div class="container max-w-5xl section-padding text-sm md:text-base mb-10 md:mb-20 group redacted">
		<div class="text-muted-foreground text-sm font-medium text-center mb-4"><a href={blogHref} class="transition-all hover:text-foreground">Blog</a> <span class="mx-1 font-light">/</span> {BREADCRUMB_LABEL[locale] ?? 'News'}</div>
		<h1 class="text-display-section font-bold text-center max-w-xl mx-auto mb-6">
			{frontmatter.title}
		</h1>
		<hr class="my-4 md:my-6 max-w-2xl mx-auto">
		<div class="mb-8 text-center text-muted-foreground text-tight">{frontmatter.author} <span class="mx-2">·</span> {pubDate}</div>
		<slot />

		{isFrench && (
			<aside class="mt-14 rounded-lg border border-secondary/15 bg-white/40 p-6 md:p-8 not-prose">
				<p class="text-foreground font-semibold mb-1">
					Ces sujets sont notre métier depuis plus de 15 ans.
				</p>
				<p class="text-muted-foreground mb-5">
					Au CHIREC, la construction du planning mensuel des urgences est passée de 4 jours
					à 4–5 heures (étude de cas, 2025). Voyez ce que Momentum donnerait sur vos propres plannings.
				</p>
				<div class="flex flex-wrap gap-3">
					<a href="/fr/demo/">
						<Button size="lg" className="rounded-full px-5 font-bold">Demander une démo</Button>
					</a>
					<a href="/fr/cas-clients/">
						<Button size="lg" variant="ghost" className="rounded-full px-4 font-semibold">Voir les cas clients</Button>
					</a>
				</div>
			</aside>
		)}
	</div>
</BaseLayout>
