---
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import HalftonePattern from '@/components/elements/HalftonePattern.astro';
import MMIcon from '@/assets/logos/MM-Icon.svg';

interface Props {
  demoHref?: string;
}
const { demoHref = '/fr/demo/' } = Astro.props;
---

<section id="cta" class="section-padding">

  <div class="container">
    <Card className="relative bg-white/15">
      <HalftonePattern />
      <div class="relative z-10 mx-auto max-w-3xl space-y-6 p-6 text-center md:space-y-8 md:p-8 lg:p-12">
        <div class="space-y-4">
          <MMIcon class="inline-block size-16 "/>
          <h2 class="text-display-section text-foreground mt-5 tracking-tight">
            Voyez Momentum sur vos propres plannings
          </h2>
          <p class="text-muted-foreground text-lead">
            La démonstration part de vos cas réels — gardes, astreintes, règles locales, multi-sites — et montre le temps que votre service peut récupérer chaque mois.
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={demoHref} class="inline-block">
            <Button
              size="lg"
              className="mt-2 border border-white/50 rounded-full pl-5.5! before:rounded-full shadow-sm shadow-primary/50 hover:shadow-md font-bold transition-all duration-200 scale-100 hover:scale-106"
            >
              Demander une démo
            </Button>
          </a>
        </div>
      </div>
    </Card>
  </div>
</section>
