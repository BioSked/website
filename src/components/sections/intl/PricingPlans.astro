---
import { PricingCards } from '@/components/sections/PricingCards.tsx';
import cyanDust from '@/assets/layout/cyan-dust_background.webp';
import type { PricingPlansContent } from '@/i18n/pricingPlans';

/** Localized version of the English pricing-tiers section (same cards, same layout). */
interface Props {
    content: PricingPlansContent;
}
const { content } = Astro.props;
---

<section class="section-padding relative overflow-hidden">
    <div class="absolute top-0 left-0 size-[800px] bg-no-repeat pointer-events-none" style={'background-image: url("' + cyanDust.src + '"); background-position-y: 0%; transform:scaleX(-1);'}></div>
    <div class="text-orange-400 text-blue-500 from-background/30 to-background/30 pointer-events-none absolute inset-0 z-1 bg-linear-to-b"></div>

    <div class="container relative z-10">
        <div class="text-center">
            <h2 class="text-display-section font-bold tracking-tight">{content.heading}</h2>
            <p class="text-muted-foreground mx-auto mt-3 max-w-2xl text-md lg:text-lg">{content.sub}</p>
        </div>
        <PricingCards client:load plans={content.plans} labels={content.labels} />
    </div>
</section>
