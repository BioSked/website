---
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { Quote } from "lucide-astro";
---

<BaseLayout 
  title="Demander une démo | BioSked Momentum Suisse" 
  description="Planifiez une démonstration Momentum sur vos propres cas : gardes, désidératas, multi-sites, badgeage. Démo, cadrage, proposition sur mesure."
>
    <div class="container section-padding">
      <h1 class="text-2xl sm:text-4xl text-center font-bold max-w-4xl mx-auto">Voyons comment Momentum peut s’adapter à votre organisation</h1>
      <p class="text-md sm:text-lg text-center mt-4 mb-10 text-muted-foreground max-w-xl mx-auto">Nous vous montrons, sur vos cas réels, comment automatiser la construction de plannings conformes à vos règles, sécuriser la couverture et simplifier la gestion des désidératas.</p>

      <div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-5">
        <div class="lg:col-span-3">
          <div class="bg-card-foreground transition-all duration-400 shadow-xl shadow-card-foreground/30 rounded-2xl px-4 sm:px-10 pb-10 pt-1">
            <h2 class="text-display-card text-center font-bold max-w-2xl mx-auto text-white my-5">Demander une démo</h2>
            <hr class="border-white/10">
            <div id="hubspot-demo" class="mt-5"></div>
          </div>
          <p class="text-muted-foreground text-xs mt-3 text-center">
            <a href="/fr-ch/securite-donnees/" class="hover:text-foreground transition-colors">Hébergement dans l’Union européenne · RGPD · DPA sur demande</a>
          </p>
        </div>
        <aside class="lg:col-span-2 space-y-6">
          <ol class="space-y-3">
            <li class="flex gap-3"><span class="bg-primary/10 text-accent grid size-7 shrink-0 place-items-center rounded-full text-sm font-bold">1</span><span class="text-foreground/85 text-sm">Démo personnalisée — sur vos plannings réels</span></li>
            <li class="flex gap-3"><span class="bg-primary/10 text-accent grid size-7 shrink-0 place-items-center rounded-full text-sm font-bold">2</span><span class="text-foreground/85 text-sm">Cadrage du périmètre — sites, spécialités, modules, intégrations</span></li>
            <li class="flex gap-3"><span class="bg-primary/10 text-accent grid size-7 shrink-0 place-items-center rounded-full text-sm font-bold">3</span><span class="text-foreground/85 text-sm">Proposition sur mesure — chiffrée en toute transparence</span></li>
          </ol>
          <figure class="border-l-2 border-cyan-500 pl-4">
            <Quote class="size-5 text-accent/40 mb-2" />
            <blockquote class="text-foreground/90 text-sm">Je ne m’attendais pas à ce que Momentum ait un tel impact. C’est clair, fluide, automatisé.</blockquote>
            <figcaption class="mt-2 text-xs">
              <span class="font-semibold text-foreground">Dr Frédéric Cavallotto</span>
              <span class="text-muted-foreground"> — chef du service des urgences, Hôpital de Braine-l’Alleud (CHIREC)</span>
            </figcaption>
          </figure>
          <div class="grid grid-cols-3 gap-4">
            <div><div class="font-bold text-accent">4 j → 4–5 h</div><div class="text-muted-foreground text-xs mt-1">planning mensuel (CHIREC, 2025)</div></div>
            <div><div class="font-bold text-accent">250+</div><div class="text-muted-foreground text-xs mt-1">organisations de santé</div></div>
            <div><div class="font-bold text-accent">9</div><div class="text-muted-foreground text-xs mt-1">pays</div></div>
          </div>
        </aside>
      </div>

      <script is:inline define:vars={{ thankYouPath: "/fr-ch/demo/merci/" }}>
        hbspt.forms.create({
          formInstanceId: "1",
          portalId: "25195055",
          formId: "a28f608c-a613-4fbe-a382-1fbc49b6885c",
          region: "eu1",
          locale: "fr",
          redirectUrl: thankYouPath,
          target: "#hubspot-demo",
          onFormSubmitted: function () {
            if (typeof window.bskTrackLead === 'function') window.bskTrackLead("a28f608c-a613-4fbe-a382-1fbc49b6885c");
          }
        });
      </script>
    </div>
</BaseLayout>
