---
import { LOCALE_CODES, altPathFor, splitLocale } from '@/i18n/locales';

/**
 * Client-side locale suggestion, per i18n best practice:
 * - Detection via navigator.languages (fr-CH honored; fr + Europe/Zurich
 *   timezone refines to fr-ch). No IP calls, no external requests.
 * - Auto-switch ONLY on the English homepage for first-time visitors.
 * - Elsewhere: a dismissible suggestion banner linking to the equivalent page.
 * - An explicit choice (switcher click, banner accept/dismiss) is stored in
 *   localStorage and always respected afterwards. Default stays EN.
 * - Crawlers see the normal page: no server redirects, hreflang unaffected.
 */
const { locale: current } = splitLocale(Astro.url.pathname);
const alternates: Record<string, string> = { current };
for (const code of LOCALE_CODES) alternates[code] = altPathFor(Astro.url.pathname, code);
---

<script type="application/json" id="locale-alternates" set:html={JSON.stringify(alternates)} />
<script is:inline>
(function () {
    var KEY = 'biosked-locale-pref';
    var stored = null;
    try { stored = localStorage.getItem(KEY); } catch (e) {}

    // Record explicit choices made via the language switcher anywhere on the site.
    document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest && e.target.closest('a[data-locale-choice]');
        if (a) { try { localStorage.setItem(KEY, a.getAttribute('data-locale-choice')); } catch (err) {} }
    }, true);

    var el = document.getElementById('locale-alternates');
    if (!el) return;
    var alt = {};
    try { alt = JSON.parse(el.textContent); } catch (e) { return; }
    var current = alt.current || 'en';

    // Swiss stickiness: once a visitor has been on /fr-ch/, the conversion
    // links on shared /fr/ pages keep pointing to the CHF pages.
    var FRCH_PAGES = ['/fr/pricing/', '/fr/demo/', '/fr/getquote/', '/fr/securite-donnees/', '/fr/mentions-legales/'];
    try {
        if (current === 'fr-ch') sessionStorage.setItem('biosked-frch', '1');
        var frchSticky = stored === 'fr-ch' || sessionStorage.getItem('biosked-frch') === '1';
        if (current === 'fr' && frchSticky) {
            document.querySelectorAll('a[href^="/fr/"], a[href="/fr"]').forEach(function (a) {
                var h = a.getAttribute('href');
                var hs = h.charAt(h.length - 1) === '/' ? h : h + '/';
                if (hs === '/fr/') { a.setAttribute('href', '/fr-ch/'); return; }
                if (FRCH_PAGES.indexOf(hs) !== -1) a.setAttribute('href', '/fr-ch' + hs.slice(3));
            });
        }
    } catch (e) {}

    function detect() {
        var langs = navigator.languages || [navigator.language || 'en'];
        for (var i = 0; i < langs.length; i++) {
            var l = String(langs[i]).toLowerCase();
            if (l === 'fr-ch') return 'fr-ch';
            if (l.indexOf('fr') === 0) {
                try { if (Intl.DateTimeFormat().resolvedOptions().timeZone === 'Europe/Zurich') return 'fr-ch'; } catch (e) {}
                return 'fr';
            }
            if (l.indexOf('de') === 0) return 'de';
            if (l.indexOf('nl') === 0) return 'nl';
            if (l.indexOf('it') === 0) return 'it';
            if (l.indexOf('en') === 0) return 'en';
        }
        return 'en';
    }

    if (stored) return; // explicit choice always wins
    var want = detect();
    if (want === current || !alt[want]) return;

    // First visit landing on the EN homepage: switch silently to the visitor's language.
    if (current === 'en' && location.pathname === '/') {
        location.replace(alt[want]);
        return;
    }

    // Elsewhere: polite suggestion banner.
    var STRINGS = {
        'fr':    { text: 'Cette page existe en français.', go: 'Voir la version française', stay: 'Rester ici' },
        'fr-ch': { text: 'Cette page existe en français pour la Suisse.', go: 'Voir la version suisse', stay: 'Rester ici' },
        'de':    { text: 'Diese Seite ist auf Deutsch verfügbar.', go: 'Auf Deutsch ansehen', stay: 'Hier bleiben' },
        'nl':    { text: 'Deze pagina is ook beschikbaar in het Nederlands.', go: 'In het Nederlands bekijken', stay: 'Hier blijven' },
        'it':    { text: 'Questa pagina è disponibile in italiano.', go: 'Vedi la versione italiana', stay: 'Rimani qui' },
        'en':    { text: 'This page is available in English.', go: 'View in English', stay: 'Stay here' },
    };
    var s = STRINGS[want];
    if (!s) return;

    var bar = document.createElement('div');
    bar.setAttribute('role', 'region');
    bar.setAttribute('aria-label', 'Language suggestion');
    bar.style.cssText = 'position:fixed;bottom:16px;left:50%;transform:translateX(-50%);z-index:60;background:#fff;border:1px solid rgba(0,40,80,.12);border-radius:10px;box-shadow:0 8px 30px rgba(0,20,40,.12);padding:10px 14px;display:flex;gap:12px;align-items:center;font:14px/1.4 system-ui,sans-serif;color:#0f2a43;max-width:92vw;';
    bar.innerHTML = '<span></span><a href="' + alt[want] + '" style="font-weight:600;color:#0e7490;text-decoration:none;white-space:nowrap"></a><button type="button" style="background:none;border:none;color:#64748b;cursor:pointer;white-space:nowrap"></button>';
    bar.children[0].textContent = s.text;
    bar.children[1].textContent = s.go;
    bar.children[2].textContent = s.stay;
    bar.children[1].addEventListener('click', function () { try { localStorage.setItem(KEY, want); } catch (e) {} });
    bar.children[2].addEventListener('click', function () { try { localStorage.setItem(KEY, current); } catch (e) {} bar.remove(); });
    document.body.appendChild(bar);
})();
</script>
