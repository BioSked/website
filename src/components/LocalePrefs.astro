---
import { FR_CH_LOCAL, splitLocale } from '@/i18n/locales';

/**
 * Locale preferences (no UI). Two DOM-dependent jobs, so this runs in the body:
 * - Records an explicit language choice made via the switcher (a[data-locale-choice])
 *   in localStorage 'biosked-locale-pref'. The instant-switch script in <head>
 *   (BaseHead) then always respects it.
 * - Swiss stickiness: explicit /fr-ch/ pages repair any reused French conversion
 *   links, and shared /fr/ pages retain those Swiss links until another locale is chosen.
 *
 * The old "this page is available in X" suggestion banner was removed — first-time
 * language selection is now handled silently and instantly in <head>.
 */
const { locale: current } = splitLocale(Astro.url.pathname);
const frChLinkMap = Object.fromEntries(FR_CH_LOCAL.map((rest) => [
    rest === '/' ? '/fr/' : `/fr${rest}/`,
    rest === '/' ? '/fr-ch/' : `/fr-ch${rest}/`,
]));
---

<script is:inline define:vars={{ localeCurrent: current, frChLinkMap }}>
    (function () {
        var KEY = 'biosked-locale-pref';

        // Record explicit switcher choices so auto-detect never overrides them.
        document.addEventListener('click', function (e) {
            var a = e.target && e.target.closest && e.target.closest('a[data-locale-choice]');
            if (a) { try { localStorage.setItem(KEY, a.getAttribute('data-locale-choice')); } catch (err) {} }
        }, true);

        // Repair reused French links on /fr-ch/, and keep them Swiss on shared /fr/ pages.
        try {
            var current = localeCurrent || 'en';
            if (current === 'fr-ch') sessionStorage.setItem('biosked-frch', '1');
            var stored = null;
            try { stored = localStorage.getItem(KEY); } catch (e) {}
            var frchSticky = stored === 'fr-ch' || (!stored && sessionStorage.getItem('biosked-frch') === '1');
            if (current === 'fr-ch' || (current === 'fr' && frchSticky)) {
                document.querySelectorAll('a[href^="/fr"]:not([data-locale-choice])').forEach(function (a) {
                    var h = a.getAttribute('href');
                    var url = new URL(h, location.origin);
                    var path = url.pathname.charAt(url.pathname.length - 1) === '/' ? url.pathname : url.pathname + '/';
                    var target = frChLinkMap[path];
                    if (target) a.setAttribute('href', target + url.search + url.hash);
                });
            }
        } catch (e) {}
    })();
</script>
