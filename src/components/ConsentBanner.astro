---
import { splitLocale } from '@/i18n/locales';

/**
 * Minimal consent UI, shown ONLY when the visitor is in an EU/CH timezone
 * and has made no choice yet (see BaseHead: GA loads immediately outside
 * the EU, never before consent inside it — CNIL "basic" consent mode).
 * Equal-weight Accept/Decline, choice stored 12 months, GPC honored.
 */
const { locale } = splitLocale(Astro.url.pathname);
const STRINGS: Record<string, { text: string; accept: string; decline: string; more: string }> = {
    en: { text: 'We use Google Analytics to measure how this site is used.', accept: 'Accept', decline: 'Decline', more: 'Privacy' },
    fr: { text: 'Nous utilisons Google Analytics pour mesurer l’audience de ce site.', accept: 'Accepter', decline: 'Refuser', more: 'Confidentialité' },
    'fr-ch': { text: 'Nous utilisons Google Analytics pour mesurer l’audience de ce site.', accept: 'Accepter', decline: 'Refuser', more: 'Confidentialité' },
    de: { text: 'Wir verwenden Google Analytics zur Reichweitenmessung dieser Website.', accept: 'Akzeptieren', decline: 'Ablehnen', more: 'Datenschutz' },
    nl: { text: 'We gebruiken Google Analytics om het gebruik van deze site te meten.', accept: 'Accepteren', decline: 'Weigeren', more: 'Privacy' },
    it: { text: 'Utilizziamo Google Analytics per misurare l’utilizzo di questo sito.', accept: 'Accetta', decline: 'Rifiuta', more: 'Privacy' },
};
const s = STRINGS[locale] ?? STRINGS.en;
---

<div id="bsk-consent" hidden class="fixed bottom-4 left-4 z-[70] max-w-[340px] rounded-lg border border-secondary/15 bg-white p-4 shadow-xl text-sm text-foreground">
    <p class="mb-3 leading-snug">{s.text} <a href="/privacy/" class="underline text-cyan-700 hover:text-secondary">{s.more}</a></p>
    <div class="flex gap-2">
        <button id="bsk-consent-accept" type="button" class="flex-1 rounded-md border border-secondary/20 bg-secondary/10 px-3 py-1.5 font-semibold hover:bg-secondary/20 transition-colors">{s.accept}</button>
        <button id="bsk-consent-decline" type="button" class="flex-1 rounded-md border border-secondary/20 px-3 py-1.5 font-semibold hover:bg-secondary/5 transition-colors">{s.decline}</button>
    </div>
</div>

<script is:inline>
(function () {
    var box = document.getElementById('bsk-consent');
    if (!box || !window.__bskConsentPending) return;
    box.hidden = false;
    function choose(v) {
        try { localStorage.setItem('biosked-consent', JSON.stringify({ v: v, t: Date.now() })); } catch (e) {}
        box.remove();
        if (v === 'granted' && window.__bskLoadGA) window.__bskLoadGA();
    }
    document.getElementById('bsk-consent-accept').addEventListener('click', function () { choose('granted'); });
    document.getElementById('bsk-consent-decline').addEventListener('click', function () { choose('denied'); });
})();
</script>
