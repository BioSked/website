---
import { Image } from 'astro:assets';
import { Check, Smartphone } from 'lucide-astro';
import type { MobileAppContent } from '@/i18n/mobileAppContent';
import DecorativeDust from '@/components/ui/DecorativeDust.astro';
import mockupEn from '@/assets/screenshots/mobile-mockup-en.png';
import mockupFr from '@/assets/screenshots/mobile-mockup-fr.png';

interface Props {
    content: MobileAppContent;
}
const { content } = Astro.props;
const mockup = content.imageVariant === 'fr' ? mockupFr : mockupEn;
---

<section id="mobile-app" class="relative">
  <DecorativeDust class="absolute top-1/3 right-0 size-[800px] bg-no-repeat dust-fade pointer-events-none" />
  <div class="container section-padding relative">
    <div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="order-2 lg:order-1">
        <p class="text-secondary font-semibold">
          <Smartphone class="inline-block size-5 mb-1 mr-1" aria-hidden="true" />{content.eyebrow}
        </p>
        <h2 class="text-display-section tracking-tight mt-2">
          {content.heading}
        </h2>
        <p class="text-muted-foreground text-lead mt-4">
          {content.lead}
        </p>
        <ul class="mt-6 space-y-3">
          {content.bullets.map((b) => (
            <li class="flex items-start gap-2.5">
              <Check class="size-5 shrink-0 text-primary mt-0.5" aria-hidden="true" />
              <span class="text-foreground/90">{b}</span>
            </li>
          ))}
        </ul>
        <p class="text-muted-foreground text-sm mt-6">
          {content.calendarNote}
        </p>
        <p class="text-muted-foreground/80 text-sm font-medium mt-2">
          {content.availability}
        </p>
      </div>

      <div class="order-1 lg:order-2 relative">
        <div class={'mx-auto rounded-2xl border border-border/60 shadow-2xl shadow-secondary/20 overflow-hidden ' + (content.imageVariant === 'fr' ? 'max-w-85 sm:max-w-100' : 'max-w-70 sm:max-w-80')}>
          <Image
            src={mockup}
            alt={content.imageAlt}
            width={840}
            widths={[420, 840, 1260]}
            sizes={content.imageVariant === 'fr' ? '(min-width: 640px) 400px, 340px' : '(min-width: 640px) 320px, 280px'}
            format="webp"
            quality={85}
            loading="lazy"
            class="w-full h-auto"
          />
        </div>
      </div>
    </div>
  </div>
</section>
